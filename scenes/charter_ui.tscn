text = "ТОРГОВАЯ ХАРТИЯ ГНОМОВ"
horizontal_alignment = 1

[node name="Body" type="Label" parent="Root/Panel/Margin/VBox"]
custom_minimum_size = Vector2(0, 280)
theme_override_colors/font_color = Color(0.22, 0.14, 0.06, 1)
theme_override_font_sizes/font_size = 16
text = "Поздравляю, бэйби — ты в деле. Скрепим всё по чести. Правила добросовестной торговли таковы:

§1. Будь честен о качестве товара. Гнилое — зови гнилым, котик.
§2. Не обвешивай покупателя: рука на весах быстро становится рукой в банке с рассолом.
§3. Не обсчитывай покупателя — каждая монета на счету, ягодка.
§4. Всегда плати твёрдой монетой. Никаких расписок, обещаний и поцелуйчиков.
§5. Всякий, кто нарушит Хартию, будет жестоко отомщён — до седьмого колена. Йе-е.

Подпись скрепляет вечную дружбу и взаимное обогащение, бэйби."
autowrap_mode = 3

[node name="SignRow" type="HBoxContainer" parent="Root/Panel/Margin/VBox"]
