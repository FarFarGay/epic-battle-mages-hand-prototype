anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -84.0
offset_bottom = -16.0
mouse_filter = 2

; HP/MP/сила башни (верх по центру). Бары — реальные узлы (видно/двигаешь в редакторе),
; код только обновляет value/текст. SuperBar прячется кодом, если великий удар закрыт.
