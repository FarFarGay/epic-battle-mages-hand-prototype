; --- Панель отрядов (юниты). Двигай/растягивай ЭТОТ узел в редакторе — gameplay_hud.gd
; кладёт карточки внутрь SquadList. Дефолт: правый столбец под ресурсами/журналом. ---
[node name="SquadScroll" type="ScrollContainer" parent="."]
anchor_left = 1.0
anchor_top = 0.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -300.0
offset_top = 296.0
offset_right = -10.0
offset_bottom = -16.0
