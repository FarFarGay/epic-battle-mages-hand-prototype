mouse_filter = 2
theme_override_constants/separation = 6

; --- Якоря панелей HUD. Двигай/растягивай ЭТИ узлы в редакторе — gameplay_hud.gd
; кладёт соответствующий виджет внутрь, заполняя якорь. Так весь HUD позиционируется
; мышкой, без правок кода. ---

; Бар заклинаний (низ по центру). Полоса во всю ширину снизу, бар центрируется внутри.
[node name="ActionBarAnchor" type="Control" parent="."]
