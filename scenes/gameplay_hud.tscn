theme_override_constants/separation = 6

; Уровень = количество палаток
[node name="TentRow" type="HBoxContainer" parent="RightPanel/Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Icon" type="ColorRect" parent="RightPanel/Margin/VBox/TentRow"]
