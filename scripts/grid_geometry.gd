class_name GridGeometry
extends RefCounted
## Геометрия полярного грида строительства — ЕДИНЫЙ источник дефолтов формы
## ring-0 ячейки. Используют:
##   - BuildGrid (рантайм) — дефолты @export'ов core_radius/ring_band/etc;
##   - tools/bake_generator.gd (офлайн-бейк) — лепит тело-модель генератора
##     ровно под ту же ячейку.
## БЕЗ зависимостей (никаких autoload/EventBus/Camp), чтобы headless-бейк мог
## preload'ить этот файл, не затягивая весь рантайм-граф. Меняешь форму грида
## здесь → перепеки генератор:
##   godot --headless --script res://tools/bake_generator.gd

## Сегментов в кольце 0 (генераторное кольцо вокруг ядра).
const SEGMENTS_RING0 := 4
## Радиус дворика-ядра = внутренний радиус кольца 0 (дыра под харвестер).
## Зазор ядро↔кольцо = CORE_RADIUS − радиус_харвистера(~1.71) = ~1.4м ≈ 1.7
## ширины скелета (0.8м) — кольцевой проход вокруг ядра, чтобы юниты обходили
## его по «дворику». Чуть больше 1.5 скелетов: при ровно 1.2м навмеш-коридор
## (agent_radius 0.4 + cell 0.5) проходимую полосу не оставляет.
const CORE_RADIUS := 3.1
## Радиальная толщина одного кольца (глубина здания).
const RING_BAND := 1.8
## Радиальный проход МЕЖДУ кольцами (м) — «улица», чтобы юниты обходили здания
## и между рядами. Кольцо r начинается на CORE_RADIUS + r·(RING_BAND + RING_GAP).
const RING_GAP := 1.4
## Угловой проход между ячейками в кольце — задаётся МЕТРИЧЕСКИ (м), на ВНУТРЕННЕМ
## радиусе кольца (там улица у́же всего). В градусы переводится по радиусу, иначе
## на внешних кольцах фиксированный угол сжимал бы проход в метрах. ~1.4м ≈ 1.7
## ширины скелета — навмеш (agent 0.4 + cell 0.5) гарантированно пускает юнита.
const CELL_GAP_M := 1.4
