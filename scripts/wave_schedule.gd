class_name WaveSchedule
extends Resource
## Расписание осады для одного POI. Прикладывается в инспекторе костра
## ([QuestActor.wave_schedule]). Когда лагерь развёртывается на этом POI,
## WaveDirector берёт schedule и проигрывает массив [WaveStage] по порядку.
##
## Стадии — линейная цепочка эскалации: 0 → 1 → 2 → … → N. Каждая стадия
## длится свой `duration` и задаёт темп волн (`wave_interval`,
## `skeletons_per_wave`). Последняя стадия залипает до тех пор, пока
## игрок не свернёт лагерь (или не проиграет).
##
## Пример (стандартная сложность):
##   stages[0]: duration=60, interval=60, per_wave=5  — «разведка» (5 скел/мин)
##   stages[1]: duration=90, interval=45, per_wave=8  — «давление» (~10 скел/мин)
##   stages[2]: duration=∞,  interval=30, per_wave=12 — «осада» (24 скел/мин)
##
## Дизайнер крутит без правки кода: создаёт `.tres` ресурс с массивом стадий,
## кладёт в инспекторе костра. Разные POI могут иметь разный темп — лёгкие
## (стартовые) с пологим расписанием, поздние — с агрессивным.

## Массив стадий по порядку. Если пуст — POI спокоен (deploy ничего не
## триггерит). Если ровно одна стадия — она просто залипает.
@export var stages: Array[WaveStage] = []


## True если расписание содержит хотя бы одну стадию. Используется
## WaveDirector'ом — без stages POI не активирует осаду.
func is_empty() -> bool:
	return stages.is_empty()


## Безопасный геттер стадии по индексу с клампом до последней. Это даёт
## «залипание» на финальной стадии: если индекс ушёл за конец массива,
## возвращаем последнюю — её темп играет до свёртки лагеря.
func get_stage(index: int) -> WaveStage:
	if stages.is_empty():
		return null
	var clamped: int = clampi(index, 0, stages.size() - 1)
	return stages[clamped]
