class_name WaveStage
extends Resource
## Одна стадия осады POI. Используется внутри [WaveSchedule] как элемент массива
## stages — описывает «темп» волн на текущем уровне эскалации.
##
## Жизненный цикл стадии в WaveDirector:
## 1. На входе в стадию таймер выставляется в `wave_interval` (первая волна
##    идёт через wave_interval секунд после deploy / перехода стадии).
## 2. Каждые `wave_interval` секунд WaveDirector спавнит одну «волну». Что
##    она содержит — зависит от настроек ниже:
##    - **Новая модель:** массив `groups: Array[CombatGroup]`. Каждая группа
##      имеет свою композицию (типы юнитов и их количества) и свою spawn
##      zone (если `spawn_zone_index ≥ 0` — конкретная, иначе random).
##      Несколько групп = многофронтовая атака за один залп.
##    - **Legacy:** если `groups` пуст, fallback на `skeletons_per_wave`:
##      `count` скелетов из одной случайной live zone (single-front).
## 3. По истечении `duration` (с момента входа) — переход в stages[i+1].
##    Если это последняя — режим залипает (последняя стадия играет вечно
##    пока лагерь стоит).
##
## Дизайнерская идея: первая стадия — «разведка», темп низкий, состав
## простой. Каждая следующая увеличивает темп И/ИЛИ усложняет композицию
## (добавляет лучников, мобильных юнитов, многофронт). Это даёт нелинейный
## рост угрозы во времени без магических чисел в коде WaveDirector'а.

## Длительность этой стадии (с). По истечении — переход в stages[i+1].
@export var duration: float = 60.0

## Период между волнами в этой стадии (с). Меньше = темп выше.
@export var wave_interval: float = 60.0

## Боевые группы в одной волне. Каждая группа = композиция юнитов +
## spawn zone + кластер. Несколько групп с разными spawn_zone_index =
## многофронтовая атака. Если массив пуст — fallback на legacy
## `skeletons_per_wave` (см. ниже). Designer заполняет один из двух,
## не оба.
@export var groups: Array[CombatGroup] = []

## **Legacy.** Сколько скелетов в одной волне для старой single-front модели.
## Используется ТОЛЬКО если `groups` пуст. Группой спавнятся в радиусе
## WaveDirector.wave_group_radius вокруг точки спавна. Существующие .tres
## (`wave_schedule_default.tres`) используют только это поле — новая
## система обратно совместима.
@export var skeletons_per_wave: int = 5

## Если true — каждая волна выбирает ОДИН случайный preset из `groups`
## вместо спавна всех одновременно. Используется когда дизайнер задаёт
## `groups` как массив пресетов («чистые скелеты», «скелеты+лучники»,
## «разведка»), и хочет чтобы WaveDirector каждую волну подкидывал случайный
## набор с случайной стороны. spawn_zone_index в группах при этом обычно
## оставляют -1 (random zone), что даёт разные направления атаки.
##
## False (legacy) — все группы спавнятся одновременно как многофронт.
@export var random_groups: bool = false

## Период появления одиночного «разведчика» (с). 0 = выключено.
## Параллельный волнам канал микро-угроз: между большими залпами игроку
## периодически подбрасывают одиночку — рука всегда занята. Не консумит
## SpawnZone.waves_left, не считается «волной» для budget'а зоны.
##
## Дизайнерский паттерн «фаза подготовки»: stage 0 с большим wave_interval
## (90с) и маленьким scout_interval (15с) — игрок строит, периодически
## отбивается от одиночек, не «спит». Поздние стадии могут scout_interval
## убирать (=0) — там основной поток через групповые волны.
@export var scout_interval: float = 0.0


## True если эта стадия использует новую модель (массив `groups` непуст).
## WaveDirector ветвится по этому флагу.
func has_groups() -> bool:
	return not groups.is_empty()
